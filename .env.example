# Database Configuration
# Both variables must be set to the same value.
# POSTGRES_PASSWORD    — used by the postgres container to initialise the DB
# DB_POSTGRESDB_PASSWORD — used by n8n to connect (note the double "DB" in the name)
POSTGRES_PASSWORD=CHANGE_ME_postgres_password_here
DB_POSTGRESDB_PASSWORD=CHANGE_ME_postgres_password_here

# N8N Authentication
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_n8n_password_here

# N8N Host Configuration
# For local access use: localhost
# For network access use: your server IP (e.g., 192.168.1.100)
N8N_HOST=localhost

# Secure cookie — set false for HTTP, true when behind HTTPS reverse proxy
N8N_SECURE_COOKIE=false

# Timezone (see: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=America/Chicago

# Optional: Encryption key for credentials (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=
