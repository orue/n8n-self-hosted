# ─────────────────────────────────────────────────────────────────────────────
# N8N Deployment — Environment Configuration
# Copy to .env and fill in all CHANGE_ME values before running ./setup.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD    — used by the postgres container to initialise the DB
# DB_POSTGRESDB_PASSWORD — used by n8n to connect (note the double "DB")
# Both must be set to the same value.
POSTGRES_PASSWORD=CHANGE_ME_postgres_password_here
DB_POSTGRESDB_PASSWORD=CHANGE_ME_postgres_password_here

# ── N8N Authentication ────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_n8n_password_here

# ── N8N Host ─────────────────────────────────────────────────────────────────
# For local access:   localhost
# For network access: your server IP (e.g. 192.168.1.100)
# For production:     your domain name (e.g. n8n.example.com)
N8N_HOST=localhost

# Set to https if you are behind a TLS-terminating reverse proxy (nginx, Caddy…)
N8N_PROTOCOL=http

# Set false for plain HTTP; true when behind an HTTPS reverse proxy
N8N_SECURE_COOKIE=false

# Required for HTTPS deployments — full public URL for webhook reception
# WEBHOOK_URL=https://n8n.example.com/

# ── Encryption Key ────────────────────────────────────────────────────────────
# Protects stored credentials in the database.
# Leave blank — setup.sh generates a secure key and saves it here automatically.
# If you set it manually: openssl rand -hex 32
# IMPORTANT: Never change this value after workflows are running — you will
# lose access to all stored credentials.
N8N_ENCRYPTION_KEY=

# ── Timezone ─────────────────────────────────────────────────────────────────
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/Chicago

# ── Optional: Email / SMTP ───────────────────────────────────────────────────
# Uncomment and fill in to enable password-reset emails and workflow notifications.
# N8N_EMAIL_MODE=smtp
# N8N_SMTP_HOST=smtp.example.com
# N8N_SMTP_PORT=587
# N8N_SMTP_USER=your@email.com
# N8N_SMTP_PASS=your_smtp_password
# N8N_SMTP_SENDER=n8n@example.com
